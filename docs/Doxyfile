PROJECT_NAME           = "spraybus"
PROJECT_BRIEF          = "Tiny ENet-backed pub/sub message bus"
PROJECT_NUMBER         = 0.1
OUTPUT_DIRECTORY       = api
CREATE_SUBDIRS         = NO
INPUT                  = ../README.md ../include
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = ../README.md

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
EXCLUDE_SYMBOLS        = fmtquill::* quill::* spraybus::common::interrupts_impl::*

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = ..

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

QUIET                  = NO
